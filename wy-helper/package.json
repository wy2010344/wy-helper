{
  "name": "wy-helper",
  "author": "wy2010344",
  "version": "1.1.2",
  "license": "MIT",
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "description": "A comprehensive JavaScript utility library with various helper functions",
  "keywords": [
    "javascript",
    "utilities",
    "helper",
    "tools",
    "kanren",
    "parser",
    "router"
  ],
  "homepage": "https://github.com/wy2010344/wy-helper#readme",
  "bugs": {
    "url": "https://github.com/wy2010344/wy-helper/issues"
  },
  "typings": "dist/index.d.ts",
  "module": "dist/index.mjs",
  "main": "dist/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wy2010344/wy-helper.git",
    "directory": "wy-helper"
  },
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./tokenParser": {
      "development": "./src/tokenParser/index.ts",
      "types": "./dist/tokenParser.d.ts",
      "import": "./dist/tokenParser.mjs",
      "require": "./dist/tokenParser.js"
    },
    "./infixLang": {
      "development": "./src/infixLang/index.ts",
      "types": "./dist/infixLang.d.ts",
      "import": "./dist/infixLang.mjs",
      "require": "./dist/infixLang.js"
    },
    "./kanren": {
      "development": "./src/kanren/index.ts",
      "types": "./dist/kanren.d.ts",
      "import": "./dist/kanren.mjs",
      "require": "./dist/kanren.js"
    },
    "./ObserverCenter": {
      "development": "./src/observerCenter/index.ts",
      "types": "./dist/observerCenter.d.ts",
      "import": "./dist/observerCenter.mjs",
      "require": "./dist/observerCenter.js"
    },
    "./router": {
      "development": "./src/router/index.ts",
      "types": "./dist/router.d.ts",
      "import": "./dist/router.mjs",
      "require": "./dist/router.js"
    },
    "./forceLayout": {
      "development": "./src/forceLayout/index.ts",
      "types": "./dist/forceLayout.d.ts",
      "import": "./dist/forceLayout.mjs",
      "require": "./dist/forceLayout.js"
    },
    "./viteImportmap": {
      "development": "./src/viteImportmap/index.ts",
      "types": "./dist/viteImportmap.d.ts",
      "import": "./dist/viteImportmap.mjs",
      "require": "./dist/viteImportmap.js"
    },
    "./infix-o": {
      "development": "./src/infix-o/index.ts",
      "types": "./dist/infix-o.d.ts",
      "import": "./dist/infix-o.mjs",
      "require": "./dist/infix-o.js"
    },
    "./state-function": {
      "development": "./src/state-function/index.ts",
      "types": "./dist/state-function.d.ts",
      "import": "./dist/state-function.mjs",
      "require": "./dist/state-function.js"
    }
  },
  "files": [
    "dist",
    "src",
    "tokenParser",
    "kanren",
    "Vue",
    "router",
    "infix-o"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint src/ --fix",
    "lint:check": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "d3-binarytree": "catalog:",
    "d3-octree": "catalog:",
    "d3-quadtree": "catalog:"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/prettier-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/d3-quadtree": "catalog:",
    "@types/node": "catalog:",
    "lint-staged": "catalog:",
    "tsdown": "catalog:",
    "vite": "catalog:"
  }
}