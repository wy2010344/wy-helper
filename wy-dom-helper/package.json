{
  "name": "wy-dom-helper",
  "author": "wy2010344",
  "version": "2.0.1",
  "license": "MIT",
  "description": "DOM manipulation utilities and helpers for web development",
  "keywords": [
    "dom",
    "utilities",
    "web",
    "css",
    "canvas",
    "contenteditable"
  ],
  "homepage": "https://github.com/wy2010344/wy-helper#readme",
  "bugs": {
    "url": "https://github.com/wy2010344/wy-helper/issues"
  },
  "typings": "dist/index.d.ts",
  "module": "dist/index.mjs",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./contentEditable": {
      "development": "./src/contentEditable/index.ts",
      "types": "./dist/contentEditable.d.ts",
      "import": "./dist/contentEditable.mjs",
      "require": "./dist/contentEditable.js"
    },
    "./canvas": {
      "development": "./src/canvas/index.ts",
      "types": "./dist/canvas.d.ts",
      "import": "./dist/canvas.mjs",
      "require": "./dist/canvas.js"
    },
    "./window-theme": {
      "development": "./src/window-theme/index.ts",
      "types": "./dist/window-theme.d.ts",
      "import": "./dist/window-theme.mjs",
      "require": "./dist/window-theme.js"
    },
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wy2010344/wy-helper.git",
    "directory": "wy-dom-helper"
  },
  "files": [
    "dist",
    "src",
    "contentEditable",
    "canvas"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint src/ --fix",
    "lint:check": "eslint src",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@material/material-color-utilities": "^0.4.0",
    "@repo/eslint-config": "workspace:*",
    "@repo/prettier-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/stylis": "^4.2.6",
    "lint-staged": "^16.2.4",
    "tsdown": "latest"
  },
  "peerDependencies": {
    "wy-helper": "workspace:*"
  },
  "dependencies": {
    "csstype": "^3.1.3",
    "linebreak": "^1.1.0",
    "stylis": "^4.3.1"
  },
  "packageManager": "pnpm@10.33.0"
}